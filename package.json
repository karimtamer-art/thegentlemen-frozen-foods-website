{
  "name": "thegentlemen-website",
  "version": "1.0.0",
  "description": "TheGentlemen Frozen Foods — production static website",
  "private": true,
  "scripts": {
    "lint:html": "htmlhint \"**/*.html\" --config .htmlhintrc",
    "lint:css": "stylelint \"css/**/*.css\"",
    "lint:js": "eslint \"js/**/*.js\"",
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js",
    "format": "prettier --write \"**/*.{html,css,js}\"",
    "format:check": "prettier --check \"**/*.{html,css,js}\"",
    "audit:lighthouse": "npx lighthouse http://localhost:3001 --output=html --output-path=./reports/lighthouse.html --chrome-flags=\"--headless\"",
    "audit:a11y": "npx axe http://localhost:3001 --save=reports/a11y-report.json",
    "serve": "npx serve . -p 3001",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:report": "npx playwright show-report"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.10.1",
    "@axe-core/playwright": "^4.11.1",
    "@html-eslint/eslint-plugin": "^0.28.0",
    "@html-eslint/parser": "^0.28.0",
    "@playwright/test": "^1.50.1",
    "eslint": "^9.22.0",
    "htmlhint": "^1.5.0",
    "lighthouse": "^12.5.1",
    "prettier": "^3.5.3",
    "serve": "^14.2.4",
    "stylelint": "^16.15.0",
    "stylelint-config-standard": "^37.0.0"
  }
}
